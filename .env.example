# ── Next.js / Auth.js (Google sign-in) ───────────────
# Generate secret: `openssl rand -base64 32`
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Origins for OAuth redirect (e.g. http://localhost:3000 in dev)
AUTH_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
# Comma-separated Google emails that skip the waitlist survey and get full party intake
PARTY_PLANNING_ALLOWLIST_EMAILS=
# Optional: same value in FastAPI as INTERNAL_CHAT_SECRET / internal_chat_secret for chat routes
INTERNAL_CHAT_SECRET=

# ── App ──────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true
LOG_LEVEL=DEBUG

# ── Postgres ─────────────────────────────────────────
POSTGRES_USER=concierge
POSTGRES_PASSWORD=changeme
POSTGRES_DB=concierge
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://concierge:changeme@postgres:5432/concierge

# ── Redis ────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── OpenAI ───────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Anthropic ────────────────────────────────────────
ANTHROPIC_API_KEY=...

# ── Twilio (WhatsApp) ───────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Vapi (Voice Calls) ──────────────────────────────
VAPI_API_KEY=...
VAPI_PHONE_NUMBER_ID=...

# ── SerpAPI ──────────────────────────────────────────
SERPAPI_KEY=...

# ── Exa (AI Search) ──────────────────────────────────
EXA_API_KEY=...

# ── Browserbase (Headless Browser) ───────────────────
BROWSERBASE_API_KEY=...
BROWSERBASE_PROJECT_ID=...

# ── CORS (comma-separated origins for production) ────
CORS_ORIGINS=https://your-app.vercel.app

# ── Next.js (Vercel) ───────────────────────────────────
# FastAPI base URL for Next API routes (chat, events, waitlist). Required in production.
BACKEND_URL=http://localhost:8000
# Opt-in: marketing-only deploy (404 for /api/chat, /api/waitlist, etc.)
# LANDING_ONLY=1
