# ── App ──────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true
LOG_LEVEL=DEBUG

# ── Postgres ─────────────────────────────────────────
POSTGRES_USER=concierge
POSTGRES_PASSWORD=changeme
POSTGRES_DB=concierge
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://concierge:changeme@postgres:5432/concierge

# ── Redis ────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── OpenAI ───────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Anthropic ────────────────────────────────────────
ANTHROPIC_API_KEY=...

# ── Twilio (WhatsApp) ───────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Vapi (Voice Calls) ──────────────────────────────
VAPI_API_KEY=...
VAPI_PHONE_NUMBER_ID=...

# ── SerpAPI ──────────────────────────────────────────
SERPAPI_KEY=...

# ── CORS (comma-separated origins for production) ────
CORS_ORIGINS=https://your-app.vercel.app

# ── Next.js (Vercel) ───────────────────────────────────
# URL of the FastAPI backend (waitlist form proxy). Required in production.
BACKEND_URL=http://localhost:8000
# On Vercel, routes are restricted to / and /api/landing-waitlist unless set to 0.
# LANDING_ONLY=0
